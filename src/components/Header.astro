---
const path = Astro.url.pathname;
const isActive = (prefix: string) => path === prefix || path.startsWith(prefix + "/");
---

<header class="sticky top-0 z-30 backdrop-blur-sm bg-[color:var(--color-paper)]/85 border-b border-[color:var(--color-rule)]">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 h-14 flex items-center justify-between">
    <a href="/" class="field-title text-[0.78rem] sm:text-[0.85rem] transition-colors">
      <span class="text-[color:var(--color-ink)]">Giffen</span><span class="text-[color:var(--color-bark)]">labs</span>
    </a>

    <nav class="hidden sm:flex items-center gap-7 label">
      <a
        href="/specimens"
        class={`hover:text-[color:var(--color-bark)] transition-colors ${isActive("/specimens") ? "text-[color:var(--color-bark)] underline underline-offset-4 decoration-[color:var(--color-ochre)]" : ""}`}
      >
        Specimens
      </a>
      <a
        href="/journal"
        class={`hover:text-[color:var(--color-bark)] transition-colors ${isActive("/journal") ? "text-[color:var(--color-bark)] underline underline-offset-4 decoration-[color:var(--color-ochre)]" : ""}`}
      >
        Journal
      </a>
      <a
        href="https://giffen.me"
        rel="noopener"
        class="hover:text-[color:var(--color-bark)] transition-colors"
      >
        giffen.me <span aria-hidden="true">↗</span>
      </a>
    </nav>

    <button
      id="menu-toggle"
      class="sm:hidden label"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      Menu
    </button>
  </div>

  <div
    id="mobile-menu"
    class="hidden sm:hidden fixed inset-0 z-40 bg-[color:var(--color-paper)] flex flex-col items-center justify-center gap-8"
  >
    <button
      id="menu-close"
      class="absolute top-4 right-5 label"
      aria-label="Close menu"
    >
      Close
    </button>
    <a href="/specimens" class="font-[family-name:var(--font-display)] text-3xl">Specimens</a>
    <a href="/journal" class="font-[family-name:var(--font-display)] text-3xl">Journal</a>
    <a href="https://giffen.me" rel="noopener" class="font-[family-name:var(--font-display)] text-3xl">giffen.me ↗</a>
  </div>
</header>

<script is:inline>
  (function () {
    const toggle = document.getElementById("menu-toggle");
    const close = document.getElementById("menu-close");
    const menu = document.getElementById("mobile-menu");
    if (!toggle || !menu || !close) return;
    toggle.addEventListener("click", () => {
      menu.classList.remove("hidden");
      toggle.setAttribute("aria-expanded", "true");
    });
    close.addEventListener("click", () => {
      menu.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
    });
  })();
</script>
