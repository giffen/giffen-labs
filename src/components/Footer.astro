---
const year = new Date().getFullYear();
---

<footer class="border-t border-[color:var(--color-rule)] mt-16">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-10 flex flex-col items-center text-center gap-2">
    <div class="inline-block border border-[color:var(--color-ink)] px-3 py-1.5 label-bark">
      Giffenlabs.ca
    </div>
    <p class="font-[family-name:var(--font-display)] italic text-[color:var(--color-ink-soft)] text-sm mt-2">
      Field notes from the build.
    </p>
    <p class="label mt-1">
      Andrew Giffen — Toronto, ON · Est. 2026
    </p>
    <p class="label opacity-60 mt-3">© {year}</p>
  </div>
</footer>
